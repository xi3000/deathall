local function getHRP()
    local char = player.Character
    if char then
        hrp = char:FindFirstChild("HumanoidRootPart") or char:FindFirstChild("UpperTorso") or char:FindFirstChild("Torso")
    end
    return hrp ~= nil
end

local function toggleFreeze()
    if not getHRP() then
        StarterGui:SetCore("SendNotification", {
            Title = "Error"; Text = "Waiting for character..."; Duration = 3
        })
        return
    end

    if not isFrozen then
        fixedY = hrp.Position.Y
        bodyPos = Instance.new("BodyPosition")
        bodyPos.MaxForce = Vector3.new(0, math.huge, 0)
        bodyPos.P = 30000
        bodyPos.D = 5000
        bodyPos.Parent = hrp

        heartbeatConn = RunService.Heartbeat:Connect(function()
            if hrp and hrp.Parent and fixedY and bodyPos then
                local pos = hrp.Position
                bodyPos.Position = Vector3.new(pos.X, fixedY, pos.Z)
            end
        end)

        isFrozen = true
        buttonBg.Color = Color3.fromRGB(255, 80, 80)
        buttonText.Text = "UNFREEZE"
        print("[DEBUG] FREEZED at Y:", math.floor(fixedY))
        StarterGui:SetCore("SendNotification", {
            Title = "FREEZED"; Text = "Height locked at Y=" .. math.floor(fixedY); Duration = 4
        })
    else
        if heartbeatConn then heartbeatConn:Disconnect() heartbeatConn = nil end
        if bodyPos then bodyPos:Destroy() bodyPos = nil end
        isFrozen = false
        buttonBg.Color = Color3.fromRGB(0, 162, 255)
        buttonText.Text = "FREEZE HEIGHT"
        print("[DEBUG] UNFREEZED")
        StarterGui:SetCore("SendNotification", {
            Title = "UNFREEZED"; Text = "Gravity normal"; Duration = 3
        })
    end
end

-- Touch/Mouse click detection (works iOS/Android)
UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        local mousePos = UserInputService:GetMouseLocation()
        local btnPos = buttonBg.Position
        local btnSize = buttonBg.Size
        if mousePos.X >= btnPos.X and mousePos.X <= btnPos.X + btnSize.X and
           mousePos.Y >= btnPos.Y and mousePos.Y <= btnPos.Y + btnSize.Y then
            toggleFreeze()
        end
    end
end)

-- Hotkey fallback: Right Shift (if Bluetooth keyboard)
UserInputService.InputBegan:Connect(function(input, gp)
    if gp then return end
    if input.KeyCode == Enum.KeyCode.RightShift then
        toggleFreeze()
    end
end)

-- Respawn auto-reapply
player.CharacterAdded:Connect(function()
    print("[DEBUG] Respawn detected - waiting...")
    wait(3)
    getHRP()
    if isFrozen and fixedY then
        wait(0.5)
        toggleFreeze()  -- Toggle off/on to reapply
        wait(0.1)
        toggleFreeze()
    end
end)

-- Initial
spawn(function()
    repeat wait(1) until player.Character
    getHRP()
end)

