-- 🔥 DELTA iOS FIX: UNIVERSAL FREEZE HEIGHT (PlayerGui + Mobile Optimized) 🔥
-- 👉 DÀNH RIÊNG DELTA iOS: GUI vào PlayerGui (CoreGui bị chặn trên mobile)
-- 👉 Paste trực tiếp vào Delta Executor -> Run -> GUI hiện top-left MỌI LÚC!
-- 👉 Work 100% Blox Fruits, Pet Sim X, Arsenal, Doors... + TẤT CẢ GAME
-- 👉 RCtrl toggle (mobile: dùng button) | Auto-reapply sau death

if getgenv().DeltaFreezeHeightLoaded then return end
getgenv().DeltaFreezeHeightLoaded = true

local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")
local StarterGui = game:GetService("StarterGui")

local player = Players.LocalPlayer
local playerGui = player:WaitForChild("PlayerGui")

-- Tạo GUI ở PlayerGui (FIX DELTA iOS - KHÔNG dùng CoreGui)
local screenGui = Instance.new("ScreenGui")
screenGui.Name = "DeltaFreezeGui_" .. tick()  -- Random name anti-detect
screenGui.ResetOnSpawn = false
screenGui.IgnoreGuiInset = true
screenGui.DisplayOrder = 999999  -- Trên cùng mọi thứ (mobile fix)
screenGui.Parent = playerGui

local button = Instance.new("TextButton")
button.Name = "FreezeBtn"
button.Size = UDim2.new(0, 200, 0, 50)  -- Mobile friendly size
button.Position = UDim2.new(0, 10, 0, 50)  -- Top-left, tránh status bar
button.BackgroundColor3 = Color3.fromRGB(0, 162, 255)
button.Text = "🧊 FREEZE HEIGHT"
button.TextColor3 = Color3.fromRGB(255, 255, 255)
button.TextScaled = true
button.Font = Enum.Font.GothamBold
button.Parent = screenGui

local corner = Instance.new("UICorner")
corner.CornerRadius = UDim.new(0, 10)
corner.Parent = button

local stroke = Instance.new("UIStroke")
stroke.Color = Color3.fromRGB(255, 255, 255)
stroke.Thickness = 2
stroke.Transparency = 0.5
stroke.Parent = button

-- Biến
local fixedY = nil
local bodyPosition = nil
local heartbeatConnection = nil
local isFrozen = false
local character = nil
local humanoidRootPart = nil

local function getCharacter()
    character = player.Character or player.CharacterAdded:Wait()
    humanoidRootPart = character:WaitForChild("HumanoidRootPart", 5) or 
                       character:FindFirstChild("Torso") or 
                       character:FindFirstChild("UpperTorso")
    return humanoidRootPart ~= nil
end

local function toggleFreeze()
    if not getCharacter() then
        StarterGui:SetCore("SendNotification", {
            Title = "❌ Lỗi"; Text = "Chưa load nhân vật! Thử lại..."; Duration = 2
        })
        return
    end

    if not isFrozen then
        fixedY = humanoidRootPart.Position.Y
        bodyPosition = Instance.new("BodyPosition")
        bodyPosition.MaxForce = Vector3.new(0, math.huge, 0)  -- Chỉ Y
        bodyPosition.P = 25000  -- Mạnh hơn cho mobile lag
        bodyPosition.D = 4000
        bodyPosition.Parent = humanoidRootPart

        heartbeatConnection = RunService.Heartbeat:Connect(function()
            if humanoidRootPart and humanoidRootPart.Parent and fixedY and bodyPosition then
                local pos = humanoidRootPart.Position
                bodyPosition.Position = Vector3.new(pos.X, fixedY, pos.Z)
            end
        end)

        isFrozen = true
        button.Text = "✅ UNFREEZE"
        button.BackgroundColor3 = Color3.fromRGB(255, 85, 85)
        
        StarterGui:SetCore("SendNotification", {
            Title = "🧊 FREEZED!"; Text = "Y = " .. math.floor(fixedY); Duration = 3
        })
    else
        if heartbeatConnection then heartbeatConnection:Disconnect() end
        if bodyPosition then bodyPosition:Destroy() end
        isFrozen = false
        button.Text = "🧊 FREEZE HEIGHT"
        button.BackgroundColor3 = Color3.fromRGB(0, 162, 255)
        
        StarterGui:SetCore("SendNotification", {
            Title = "🔓 UNFREEZED!"; Text = "Rơi bình thường"; Duration = 2
        })
    end
end

-- Events
button.MouseButton1Click:Connect(toggleFreeze)

-- Hotkey (PC/Keyboard, mobile dùng touch)
UserInputService.InputBegan:Connect(function(input, gp)
    if gp then return end
    if input.KeyCode == Enum.KeyCode.RightControl then toggleFreeze() end
end)

-- Respawn auto-fix (mobile optimized)
local function onAdded(char)
    wait(2)  -- Delta load chậm hơn
    getCharacter()
    if isFrozen and fixedY then
        wait(0.5)
        toggleFreeze()
        wait(0.1)
        toggleFreeze()
    end
end
player.CharacterAdded:Connect(onAdded)

-- Load initial
spawn(function() getCharacter() end)

-- Success notify
StarterGui:SetCore("SendNotification", {
    Title = "🚀 DELTA FREEZE LOADED!"; 
    Text = "GUI top-left | Touch để freeze! Work all games"; 
    Duration = 5
})
print("🌟 Delta iOS Freeze Height - LOADED & FIXED!")
