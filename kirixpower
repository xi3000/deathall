-- 🔥 FINAL FREEZE HEIGHT - NO GUI NEEDED - CHAT COMMAND /freeze (work Delta iOS 2026 + Death Ball) 🔥

print("[FINAL] Freeze Height loaded - Type /freeze in chat to toggle!")

local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local StarterGui = game:GetService("StarterGui")
local ChatService = game:GetService("Chat")

local player = Players.LocalPlayer
local isFrozen = false
local fixedY = nil
local bodyPos = nil
local conn = nil
local hrp = nil

local function getHRP()
    local char = player.Character
    if char then hrp = char:FindFirstChild("HumanoidRootPart") or char:FindFirstChild("UpperTorso") end
    return hrp
end

local function toggleFreeze()
    if not getHRP() then
        StarterGui:SetCore("SendNotification", {Title="Wait", Text="No character yet...", Duration=3})
        return
    end

    if not isFrozen then
        fixedY = hrp.Position.Y
        bodyPos = Instance.new("BodyPosition")
        bodyPos.MaxForce = Vector3.new(0, math.huge, 0)
        bodyPos.P = 40000
        bodyPos.D = 6000
        bodyPos.Parent = hrp

        conn = RunService.Heartbeat:Connect(function()
            if hrp and fixedY then
                local pos = hrp.Position
                bodyPos.Position = Vector3.new(pos.X, fixedY, pos.Z)
            end
        end)

        isFrozen = true
        StarterGui:SetCore("SendNotification", {Title="🧊 FREEZED", Text="Y locked at " .. math.floor(fixedY) .. " | Type /freeze to unfreeze", Duration=5})
    else
        if conn then conn:Disconnect() end
        if bodyPos then bodyPos:Destroy() end
        isFrozen = false
        StarterGui:SetCore("SendNotification", {Title="🔓 UNFREEZED", Text="Normal gravity", Duration=4})
    end
end

-- Chat command toggle
player.Chatted:Connect(function(msg)
    if msg:lower() == "/freeze" or msg:lower() == "/f" then
        toggleFreeze()
    end
end)

-- Auto re-freeze sau die
player.CharacterAdded:Connect(function()
    wait(4)
    getHRP()
    if isFrozen and fixedY then
        toggleFreeze()
        wait(0.3)
        toggleFreeze()
    end
end)

StarterGui:SetCore("SendNotification", {Title="LOADED OK", Text="Type /freeze in chat to freeze height! Works all games incl Death Ball", Duration=10})
print("[FINAL] Ready - Use chat /freeze")
