-- 🔥 DELTA iOS ULTIMATE FIX: BILLBOARD GUI FREEZE HEIGHT (Always Visible on Mobile) 🔥
-- Work 99% Delta iOS 2026 | Không dùng PlayerGui/ScreenGui | BillboardGui attach camera

if getgenv().DeltaFreezeBillboardLoaded then return end
getgenv().DeltaFreezeBillboardLoaded = true

local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")
local StarterGui = game:GetService("StarterGui")

local player = Players.LocalPlayer
local camera = workspace.CurrentCamera

-- Tạo BillboardGui (luôn hiện trên màn hình, mobile friendly)
local billboardGui = Instance.new("BillboardGui")
billboardGui.Name = "FreezeBillboard_" .. math.random(10000,99999)
billboardGui.Adornee = nil  -- Attach sau
billboardGui.Size = UDim2.new(0, 220, 0, 60)  -- To hơn cho touch
billboardGui.StudsOffset = Vector3.new(0, 3, 0)  -- Vị trí trên đầu camera
billboardGui.AlwaysOnTop = true  -- Luôn trên cùng
billboardGui.LightInfluence = 0
billboardGui.MaxDistance = math.huge
billboardGui.ResetOnSpawn = false
billboardGui.Parent = camera  -- Attach vào camera để visible mọi lúc

local frame = Instance.new("Frame")
frame.Size = UDim2.new(1, 0, 1, 0)
frame.BackgroundColor3 = Color3.fromRGB(0, 162, 255)
frame.BorderSizePixel = 0
frame.Parent = billboardGui

local corner = Instance.new("UICorner")
corner.CornerRadius = UDim.new(0, 12)
corner.Parent = frame

local button = Instance.new("TextButton")
button.Size = UDim2.new(1, -10, 1, -10)
button.Position = UDim2.new(0, 5, 0, 5)
button.BackgroundColor3 = Color3.fromRGB(0, 170, 255)
button.Text = "🧊 FREEZE HEIGHT"
button.TextColor3 = Color3.fromRGB(255, 255, 255)
button.TextScaled = true
button.Font = Enum.Font.GothamBold
button.Parent = frame

-- Biến freeze
local fixedY = nil
local bodyPosition = nil
local heartbeatConnection = nil
local isFrozen = false
local hrp = nil

local function getHRP()
    local char = player.Character
    if char then
        hrp = char:FindFirstChild("HumanoidRootPart") or char:FindFirstChild("Torso") or char:FindFirstChild("UpperTorso")
    end
    return hrp
end

local function toggleFreeze()
    if not getHRP() then
        StarterGui:SetCore("SendNotification", {Title = "❌ Lỗi", Text = "Chưa load nhân vật! Chờ tí...", Duration = 3})
        return
    end

    if not isFrozen then
        fixedY = hrp.Position.Y
        bodyPosition = Instance.new("BodyPosition")
        bodyPosition.MaxForce = Vector3.new(0, math.huge, 0)
        bodyPosition.P = 30000  -- Cao hơn cho stable mobile
        bodyPosition.D = 5000
        bodyPosition.Parent = hrp

        heartbeatConnection = RunService.Heartbeat:Connect(function()
            if hrp and hrp.Parent and fixedY and bodyPosition then
                local pos = hrp.Position
                bodyPosition.Position = Vector3.new(pos.X, fixedY, pos.Z)
            end
        end)

        isFrozen = true
        button.Text = "✅ UNFREEZE"
        button.BackgroundColor3 = Color3.fromRGB(255, 80, 80)
        StarterGui:SetCore("SendNotification", {Title = "🧊 FREEZED!", Text = "Y = " .. math.floor(fixedY), Duration = 4})
    else
        if heartbeatConnection then heartbeatConnection:Disconnect() end
        if bodyPosition then bodyPosition:Destroy() end
        isFrozen = false
        button.Text = "🧊 FREEZE HEIGHT"
        button.BackgroundColor3 = Color3.fromRGB(0, 170, 255)
        StarterGui:SetCore("SendNotification", {Title = "🔓 UNFREEZED!", Text = "Rơi bình thường", Duration = 3})
    end
end

button.MouseButton1Click:Connect(toggleFreeze)

-- Hotkey nếu dùng keyboard (Bluetooth)
UserInputService.InputBegan:Connect(function(input)
    if input.KeyCode == Enum.KeyCode.RightControl then
        toggleFreeze()
    end
end)

-- Auto update khi respawn
player.CharacterAdded:Connect(function()
    wait(2.5)  -- Delta mobile load chậm
    getHRP()
    if isFrozen and fixedY then
        wait(0.3)
        toggleFreeze()  -- Re-apply
        wait(0.1)
        toggleFreeze()
    end
end)

-- Initial load
spawn(function()
    wait(3)  -- Chờ game load
    getHRP()
end)

StarterGui:SetCore("SendNotification", {
    Title = "🚀 BILLBOARD FREEZE LOADED!",
    Text = "Button luôn hiện (trên màn hình) | Touch để freeze | Delta iOS fix!",
    Duration = 6
})

print("🌟 Billboard Freeze for Delta iOS - Should show now!")
