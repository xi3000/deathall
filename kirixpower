-- Freeze logic đơn giản (giữ nguyên như cũ nhưng debug)
local isFrozen = false
local hrp = nil

local function toggle()
    if not player.Character or not player.Character:FindFirstChild("HumanoidRootPart") then
        print("No HRP yet")
        return
    end
    hrp = player.Character.HumanoidRootPart
    
    if not isFrozen then
        local fixedY = hrp.Position.Y
        local bp = Instance.new("BodyPosition")
        bp.MaxForce = Vector3.new(0, math.huge, 0)
        bp.Position = Vector3.new(hrp.Position.X, fixedY, hrp.Position.Z)
        bp.P = 30000
        bp.D = 5000
        bp.Parent = hrp
        print("Frozen at Y:", fixedY)
        button.Text = "UNFREEZE"
        isFrozen = true
    else
        -- Tìm và destroy BodyPosition
        for _, v in pairs(hrp:GetChildren()) do
            if v:IsA("BodyPosition") then v:Destroy() end
        end
        print("Unfrozen")
        button.Text = "FREEZE HEIGHT"
        isFrozen = false
    end
end

button.MouseButton1Click:Connect(toggle)

-- Respawn handle
