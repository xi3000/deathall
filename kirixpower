local button = script.Parent
local player = game.Players.LocalPlayer
local frozen = false
local cooldown = false
local cooldownTime = 5

-- Tạo hiệu ứng highlight
local function addEffect(char)
    if char and not char:FindFirstChild("FreezeEffect") then
        local highlight = Instance.new("Highlight")
        highlight.Name = "FreezeEffect"
        highlight.FillColor = Color3.fromRGB(100, 200, 255)
        highlight.OutlineColor = Color3.fromRGB(0, 100, 255)
        highlight.FillTransparency = 0.5
        highlight.OutlineTransparency = 0
        highlight.Parent = char
    end
end

local function removeEffect(char)
    if char then
        local effect = char:FindFirstChild("FreezeEffect")
        if effect then effect:Destroy() end
    end
end

-- Cập nhật UI ban đầu
button.Text = "Freeze"
button.BackgroundColor3 = Color3.fromRGB(0, 170, 255)

button.MouseButton1Click:Connect(function()
    if cooldown then
        -- Có thể add print hoặc thông báo nếu muốn
        return
    end

    local character = player.Character
    if not character then
        button.Text = "No Character!"
        task.wait(1)
        button.Text = frozen and "Unfreeze" or "Freeze"
        return
    end

    local humanoid = character:FindFirstChildOfClass("Humanoid")
    local root = character:FindFirstChild("HumanoidRootPart")

    if not (humanoid and root) then
        button.Text = "No Humanoid/Root!"
        task.wait(1)
        button.Text = frozen and "Unfreeze" or "Freeze"
        return
    end

    frozen = not frozen
    cooldown = true

    if frozen then
        -- Freeze
        root.Anchored = true
        root.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
        root.AssemblyAngularVelocity = Vector3.new(0, 0, 0)

        addEffect(character)

        button.Text = "Unfreeze"
        button.BackgroundColor3 = Color3.fromRGB(255, 100, 100)
    else
        -- Unfreeze
        root.Anchored = false

        removeEffect(character)

        button.Text = "Freeze"
        button.BackgroundColor3 = Color3.fromRGB(0, 170, 255)
    end

    -- Cooldown (chỉ khi unfreeze mới cooldown, hoặc bạn muốn cả 2 chiều thì bỏ if)
    if not frozen then
        button.Text = "Cooldown... (" .. cooldownTime .. "s)"
        for i = cooldownTime, 1, -1 do
            task.wait(1)
            button.Text = "Cooldown... (" .. i .. "s)"
        end
    end

    cooldown = false
    button.Text = frozen and "Unfreeze" or "Freeze"
end)
