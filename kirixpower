print("[DEBUG] Script started - Freeze Height Universal vFINAL")

local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local StarterGui = game:GetService("StarterGui")

local player = Players.LocalPlayer
local playerGui = player:WaitForChild("PlayerGui", 15)

print("[DEBUG] PlayerGui loaded:", playerGui ~= nil)

-- Tạo ScreenGui siêu visible
local screenGui = Instance.new("ScreenGui")
screenGui.Name = "FreezeHeightUI_" .. math.random(1000,9999)
screenGui.ResetOnSpawn = false
screenGui.Enabled = true
screenGui.IgnoreGuiInset = true
screenGui.DisplayOrder = 2147483647  -- Max để trên cùng mọi UI
screenGui.Parent = playerGui

print("[DEBUG] ScreenGui created and parented")

local button = Instance.new("TextButton")
button.Size = UDim2.new(0, 220, 0, 70)  -- To, dễ chạm mobile
button.Position = UDim2.new(0.5, -110, 0.05, 0)  -- Giữa trên màn hình
button.BackgroundColor3 = Color3.fromRGB(30, 144, 255)
button.Text = "🧊 FREEZE HEIGHT ❄️"
button.TextColor3 = Color3.fromRGB(255, 255, 255)
button.TextScaled = true
button.Font = Enum.Font.GothamBlack
button.Parent = screenGui

local corner = Instance.new("UICorner")
corner.CornerRadius = UDim.new(0, 15)
corner.Parent = button

print("[DEBUG] Button created - should be visible now!")

-- Freeze vars
local isFrozen = false
local fixedY = nil
local bodyPos = nil
local connection = nil
local hrp = nil

local function getHRP()
    local char = player.Character
    if char then
        hrp = char:FindFirstChild("HumanoidRootPart") or char:FindFirstChild("UpperTorso") or char:FindFirstChild("Torso")
    end
    return hrp
end

local function toggleFreeze()
    if not getHRP() then
        print("[DEBUG] No HRP - waiting character")
        StarterGui:SetCore("SendNotification", {Title = "❌ Lỗi", Text = "Chưa load nhân vật! Chờ tí...", Duration = 3})
        return
    end

    if not isFrozen then
        fixedY = hrp.Position.Y
        bodyPos = Instance.new("BodyPosition")
        bodyPos.MaxForce = Vector3.new(0, math.huge, 0)  -- Chỉ lock Y
        bodyPos.P = 25000
        bodyPos.D = 4000
        bodyPos.Parent = hrp

        connection = RunService.Heartbeat:Connect(function()
            if hrp and fixedY and bodyPos then
                local pos = hrp.Position
                bodyPos.Position = Vector3.new(pos.X, fixedY, pos.Z)
            end
        end)

        isFrozen = true
        button.Text = "🔓 UNFREEZE ❄️"
        button.BackgroundColor3 = Color3.fromRGB(220, 20, 60)
        print("[DEBUG] Frozen at Y: " .. fixedY)
        StarterGui:SetCore("SendNotification", {Title = "🧊 FREEZED!", Text = "Độ cao cố định: " .. math.floor(fixedY), Duration = 4})
    else
        if connection then connection:Disconnect() end
        if bodyPos then bodyPos:Destroy() end
        isFrozen = false
        button.Text = "🧊 FREEZE HEIGHT ❄️"
        button.BackgroundColor3 = Color3.fromRGB(30, 144, 255)
        print("[DEBUG] Unfrozen")
        StarterGui:SetCore("SendNotification", {Title = "🔓 UNFREEZED!", Text = "Rơi bình thường", Duration = 3})
    end
end

button.MouseButton1Click:Connect(toggleFreeze)

-- Auto re-apply nếu đang frozen sau respawn
player.CharacterAdded:Connect(function()
    print("[DEBUG] Character respawned")
    wait(3)  -- Delta mobile load chậm
    getHRP()
    if isFrozen and fixedY then
        toggleFreeze()  -- Off rồi on lại để apply
        wait(0.2)
        toggleFreeze()
    end
end)

